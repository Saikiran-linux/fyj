# Copy to .dev.vars for local `wrangler dev`. Set the real values in production
# with `wrangler secret put <NAME>`. NEVER commit .dev.vars.

# Neon — use the DIRECT (non-pooled) URL for migrations; the Worker uses Hyperdrive.
DATABASE_URL="postgres://ops_app:PASSWORD@ep-xxxx.neon.tech/ops_console?sslmode=require"

# Better Auth session signing secret (generate: openssl rand -base64 32)
BETTER_AUTH_SECRET=""
# Better Auth base URL (the deployed origin; e.g. https://ops.fyj.app or the
# wrangler dev URL http://localhost:8787). Workers bindings aren't on
# process.env, so this is passed explicitly in src/auth.ts.
BETTER_AUTH_URL="http://localhost:8787"
# Shared secret for the one-off seed endpoint POST /api/seed/org-admin, which
# creates the first organization + its admin (username/password). Generate:
# openssl rand -base64 32. Send it as the `x-seed-secret` request header.
ADMIN_BOOTSTRAP_SECRET=""
# Browser origin(s) of the web UI, comma-separated — used for CORS + Better Auth
# trustedOrigins + cross-site cookie attributes. Local dev + the Vercel app.
WEB_ORIGIN="http://localhost:3000,https://fyj-ops-console.vercel.app"

# Embeddings (profile resume -> vector) and deep-eval (A–G + CV)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Voyage reranker (second-stage rerank of profile<->job matches, f-149). OPTIONAL:
# leave blank to disable — matching falls back to the RRF/cosine order (non-fatal).
# Model defaults to rerank-2.5; override with VOYAGE_RERANK_MODEL. Force-off with
# VOYAGE_RERANK_ENABLED=0.
VOYAGE_API_KEY=""
# VOYAGE_RERANK_MODEL="rerank-2.5"
# VOYAGE_RERANK_ENABLED="1"

# Read-only access to the fyj job index (search_jobs / get_job)
FYJ_INDEX_URL="https://mwcpoaefmggapztkxakp.supabase.co"
FYJ_INDEX_KEY=""

# ── Observability (ALL optional — every one no-ops when blank; src/observability.ts) ──
# Sentry: Worker errors + cron/queue monitors ("hourly-matcher").
SENTRY_DSN=""
# SENTRY_ENVIRONMENT="production"
# PostHog: business events (resume_uploaded, match_run, match_approved,
# tailor_completed/failed) with org group analytics. Project API key (phc_…).
POSTHOG_API_KEY=""
# POSTHOG_HOST="https://us.i.posthog.com"
# LangSmith: traces of the intake + tailor LangGraph runs. NOTE: traces contain
# résumé text — set workspace data retention accordingly.
LANGSMITH_API_KEY=""
# LANGSMITH_PROJECT="fyj-ops-console"
# Cloudflare AI Gateway: transport-level logging/cost/caching for ALL
# OpenAI/Anthropic calls via base-URL swap. Create a gateway, then:
# AI_GATEWAY_URL="https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway>"
AI_GATEWAY_URL=""
# AI_GATEWAY_TOKEN=""  # only if the gateway has authentication enabled
