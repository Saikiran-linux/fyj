{
  "name": "fyj-ops-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ops Console — multi-tenant staffing dashboard on Cloudflare Workers + Neon Postgres. Reads the fyj job index read-only via search_jobs/get_job. See docs/PLAN.md.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:policies": "psql \"$DATABASE_URL\" -f db/policies.sql",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.6",
    "@sentry/cloudflare": "^10.63.0",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.3",
    "hono": "^4.6.0",
    "langsmith": "^0.7.14",
    "postgres": "^3.4.5",
    "unpdf": "^1.6.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.7.0",
    "wrangler": "^4.107.0"
  },
  "engines": {
    "node": ">=20"
  }
}
